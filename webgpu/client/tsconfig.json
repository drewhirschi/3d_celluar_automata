{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": ["@webgpu/types"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@webgpu/client": ["./src/index.ts"]
    }
  },
  "include": ["src", "../app/**/*.ts", "../app/**/*.tsx"],
  "exclude": ["src/generated"]
}
